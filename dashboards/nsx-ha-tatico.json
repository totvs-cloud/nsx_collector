          "query": "import \"join\"\nimport \"strings\"\n\nactive = from(bucket: \"nsx\")\n  |> range(start: -3m)\n  |> filter(fn: (r) => r._measurement == \"nsx_ha_state\" and r._field == \"state_num\" and r.ha_state == \"ACTIVE\")\n  |> filter(fn: (r) => r.site =~ /${site:regex}/)\n  |> filter(fn: (r) => r.t0_name =~ /${edge_cluster:regex}/)\n  |> last()\n  |> group()\n  |> keep(columns: [\"site\", \"t0_cluster_id\", \"t0_name\", \"t1_name\", \"transport_node_id\", \"transport_node_name\"])\n\nconsensus = from(bucket: \"nsx\")\n  |> range(start: -3m)\n  |> filter(fn: (r) => r._measurement == \"nsx_ha_cluster_summary\" and r._field == \"observed\")\n  |> filter(fn: (r) => r.site =~ /${site:regex}/)\n  |> filter(fn: (r) => r.t0_name =~ /${edge_cluster:regex}/)\n  |> last()\n  |> group()\n  |> keep(columns: [\"t0_cluster_id\", \"consensus_node_id\", \"consensus_node_name\"])\n\njoin.inner(\n  left: active,\n  right: consensus,\n  on: (l, r) => l.t0_cluster_id == r.t0_cluster_id,\n  as: (l, r) => ({\n    site: l.site,\n    t0_name: l.t0_name,\n    t1_name: l.t1_name,\n    active_edge: if exists l.transport_node_name and l.transport_node_name != \"-\" and l.transport_node_name != \"\" then l.transport_node_name else strings.substring(v: l.transport_node_id, start: 0, end: 12) + \"…\",\n    consensus_edge: if exists r.consensus_node_name and r.consensus_node_name != \"-\" and r.consensus_node_name != \"\" then r.consensus_node_name else strings.substring(v: r.consensus_node_id, start: 0, end: 12) + \"…\",\n    status: if l.transport_node_id == r.consensus_node_id then \"consensus\" else \"OUTLIER\"\n  })\n)",
